<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Favicon -->
  <link rel="shortcut icon" href="/img/isotipo.ico" type="image/x-icon">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/normalize.css">
  <link rel="stylesheet" href="/css/style.css">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@200;300;400;500;600;700;800;900;1000&display=swap"
    rel="stylesheet">

  <!-- Title -->
  <title>NotesLab</title>
</head>

<body>

  <!-- Header -->
  <header class="header">
    <div class="header__box">
      <a href="/dashboard" class="header__logo-link">
        <img src="/img/logotipo.png" alt="Logo NotesLab" class="header__logo">
      </a>
      <div class="header__box-login-user">
        <h1 class="header__user-name"><%= user ? user.user : "" %></h1>
        <a type="button" href="logout"><img src="/img/logout-icon.png" alt="Log out icon" class="header__logout-icon"></a>
        <img src="/img/avatar-user.png" alt="Avatar User" class="header__avatar-user">
      </div>
    </div>
  </header>

  <!-- Dashboard -->
  <div class="dashboard__blur blur-left"></div>
  <div class="dashboard__blur blur-right"></div>
  <div class="dashboard">

    <div class="dashboard__column-notes">
      <div class="dashboard__box-scroll-notes">

        <div class="dashboard__note">
          <div class="note__header">
